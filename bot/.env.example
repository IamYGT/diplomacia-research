TELEGRAM_BOT_TOKEN=your_bot_token_here
# Yönetici Telegram ID'leri (virgülle) — intel/proxy/API; boş = yönetici yok
TELEGRAM_ADMIN_IDS=
# 1 = herkese açık global bot (varsayılan); 0 = sadece TELEGRAM_ADMIN_IDS
BOT_PUBLIC=1
# Kullanıcı başına max Diplomacia hesabı (filo)
MAX_ACCOUNTS_PER_USER=5
DIPLOMACIA_API_BASE=https://diplomacia.com.tr/api
DATA_DIR=./data
# Otomatik farm aralığı (saniye) — hap cooldown ~600
AUTOFARM_INTERVAL_SEC=620
# Stat kuyruk kontrolü (saniye) — cooldown bitince sonraki yükseltme
STAT_QUEUE_INTERVAL_SEC=15
# Readiness probe önbellek (saniye) — dashboard ek API
READINESS_CACHE_SEC=60
# Dashboard çekirdek / enrich zaman aşımı (sn)
DASHBOARD_CORE_TIMEOUT_SEC=12
DASHBOARD_ENRICH_TIMEOUT_SEC=18
# Interactive API üst timeout (Tor) — 0 = varsayılan 40
INTERACTIVE_API_TIMEOUT_SEC=15
# Readiness light probe paralel (1/0)
READINESS_PARALLEL=1
FARM_DELAY_SEC=6
# Filo paralel tick — hesaplar arası sadece başlangıç aralığı (sn); API stealth delay ayrı
FLEET_START_STAGGER_SEC=0.35
DIPLOMACIA_INTEL=/root/diplomacia-research/engagement/intel/merged.json
ACCOUNT_RULES_PATH=/root/diplomacia-research/bot/data/accounts/rules.yaml
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MODEL_FALLBACK=gemini-2.5-flash-lite,gemini-flash-lite-latest
GEMINI_COACH_MODEL=gemini-2.5-flash-lite
GEMINI_THINKING_BUDGET=0
# Panel önbellek TTL (sn) — taze / eski gösterim
SNAPSHOT_CACHE_TTL_SEC=20
SNAPSHOT_STALE_SEC=90
